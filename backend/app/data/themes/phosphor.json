  "version": "1.0.0",
  "description": "A near-black OLED theme with glowing terminal-green text.",
  "base": "dark",
  "builtin": true,
  "tokens": {
    "dark": {
      "--bg-body": "#000000",
      "--bg-sidebar": "#030503",
      "--surface": "#0a0f0a",
      "--surface-2": "#0f150f",
      "--surface-3": "#142014",
      "--surface-hover": "#111a11",
      "--border": "#1a241a",
      "--border-soft": "#101810",
      "--border-strong": "#294029",
      "--text": "#c8f7c8",
      "--text-dim": "#7fcf7f",
      "--text-faint": "#4f8f4f",
      "--text-ghost": "#2f5f2f",
      "--green": "#33ff66",
      "--green-bg": "rgba(51,255,102,0.12)",
      "--amber": "#ffcc33",
